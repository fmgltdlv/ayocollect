{
  "name": "ayocollect",
  "private": true,
  "workspaces": [
    "packages/*",
    "workers/*",
    "dashboard"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev:app": "npm run dev -w @ayocollect/app",
    "dev:dashboard": "npm run dev -w @ayocollect/dashboard",
    "deploy:app": "npm run deploy -w @ayocollect/app",
    "deploy:dashboard": "npm run build -w @ayocollect/dashboard && npx wrangler pages deploy dashboard/dist --project-name ayocollect-dashboard --commit-dirty=true",
    "deploy": "npm run deploy:app && npm run deploy:dashboard",
    "db:migrate:local": "wrangler d1 execute ayocollect-db --local --file=packages/db/migrations/001_initial.sql",
    "db:reset:local": "node -e \"require('fs').rmSync('.wrangler/state/v3/d1',{recursive:true,force:true})\" && npm run db:migrate:local",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250204.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.109.1"
  }
}
