# Worker ingest (required)
WORKER_URL=https://ayocollect.thefieldmappinggroup.workers.dev
INGEST_SECRET=your-secret-from-wrangler-secret-put

# Scrape defaults
THROTTLE_SEC=0.15
INGEST_BATCH_SIZE=50
MAX_TICKETS_PER_DAY=3999
CONSECUTIVE_MISS_LIMIT=2
SYSTEMS=digalert,usan-ca,usan-nv

# DigAlert session cookies (JSON object) — required for DigAlert hits
DIGALERT_SESSION_COOKIES={"session":"paste-cookie-value-here"}

# Optional HTTP control API (python server.py)
SCRAPER_API_HOST=0.0.0.0
SCRAPER_API_PORT=8789
SCRAPER_API_KEY=change-me-local-api-key
